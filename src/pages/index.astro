---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Author from '@/components/ui/Author.astro';
import { DEFAULT_CONFIGURATION } from '@/lib/constants';
import WorkExperience from '@/components/ui/WorkExperience.astro';
import ResearchExperience from '@/components/ui/ResearchExperience.astro';
import TeachingExperience from '@/components/ui/TeachingExperience.astro';
import ExperienceTabs from '@/components/ui/ExperienceTabs.astro';
import WritingPreview from '@/components/ui/WritingPreview.astro';
import { getPublishedPosts } from '@/lib/posts';

const entry = await getEntry('pages', 'homepage');

const jobs = await getCollection('jobs');
const researches = await getCollection('researches');
const teachings = await getCollection('teachings');
const posts = await getPublishedPosts();

const experienceTabs = [
  ...(jobs.length > 0 ? [{ id: 'work' as const, label: 'Work' }] : []),
  ...(teachings.length > 0 ? [{ id: 'teaching' as const, label: 'Teaching' }] : []),
  ...(researches.length > 0 ? [{ id: 'research' as const, label: 'Research' }] : []),
  ...(posts.length > 0 ? [{ id: 'writing' as const, label: 'Writing' }] : []),
];
---

<BaseLayout seo={entry?.data.seo}>
  <section class="py-6">
    <Container>
      <Author {...DEFAULT_CONFIGURATION.author} />
    </Container>
  </section>
  {experienceTabs.length > 0 && (
    <section class="py-6">
      <Container>
        <ExperienceTabs tabs={experienceTabs}>
          {jobs.length > 0 && (
            <ul slot="work" class="flex flex-col gap-8">
              {jobs.sort((a, b) => b.data.to - a.data.to).map((job) => <WorkExperience entry={job} />)}
            </ul>
          )}
          {teachings.length > 0 && (
            <ul slot="teaching" class="flex flex-col gap-8">
              {teachings.sort((a, b) => b.data.to - a.data.to).map((teaching) => <TeachingExperience entry={teaching} />)}
            </ul>
          )}
          {researches.length > 0 && (
            <ul slot="research" class="flex flex-col gap-8">
              {researches.sort((a, b) => b.data.to - a.data.to).map((research) => <ResearchExperience entry={research} />)}
            </ul>
          )}
          {posts.length > 0 && (
            <ul slot="writing" class="flex flex-col">
              {posts.map((post) => <WritingPreview entry={post} />)}
            </ul>
          )}
        </ExperienceTabs>
      </Container>
    </section>
  )}
</BaseLayout>
