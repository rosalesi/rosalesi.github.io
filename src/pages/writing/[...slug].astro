---
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import { formatPostAuthors, getPublishedPosts } from '@/lib/posts';
import { formatDate } from '@/lib/utils';

export async function getStaticPaths() {
  const entries = await getPublishedPosts();

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
const authors = formatPostAuthors(entry.data.authors);
const seo = {
  ...entry.data.seo,
  ...(entry.data.image && !entry.data.seo.image ? { image: entry.data.image } : {}),
};
---

<BaseLayout seo={seo}>
  <section class="py-6">
    <Container>
      <article class="flex flex-col">
        <header class="flex flex-col gap-4 pb-8 border-b border-border mb-8">
          <a href="/" class="transition-colors text-muted-foreground hover:text-foreground text-sm w-max">
            ← Back
          </a>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
            {entry.data.category && (
              <>
                <span aria-hidden="true">·</span>
                <span class="capitalize">{entry.data.category}</span>
              </>
            )}
          </div>
          <h1 class="text-3xl font-semibold text-headings tracking-tight leading-tight">
            {entry.data.title}
          </h1>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <span>{authors}</span>
            <span aria-hidden="true">·</span>
            <span>{remarkPluginFrontmatter.minutesRead}</span>
          </div>
        </header>
        {entry.data.image && (
          <div class="relative aspect-video overflow-hidden rounded-lg mb-8">
            <Image
              src={entry.data.image}
              alt={entry.data.title}
              class="object-cover"
            />
          </div>
        )}
        <div class="prose dark:prose-invert max-w-none">
          <Content />
        </div>
      </article>
    </Container>
  </section>
</BaseLayout>
