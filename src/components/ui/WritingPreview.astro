---
import type { CollectionEntry } from 'astro:content';
import { formatPostAuthors } from '@/lib/posts';
import { formatDate } from '@/lib/utils';

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const authors = formatPostAuthors(entry.data.authors);
---

<li>
  <a
    href={`/writing/${entry.id}/`}
    class="group block py-5 border-b border-border first:pt-0 last:border-b-0 transition-colors"
  >
    <div class="flex flex-col gap-2">
      <h3 class="text-headings font-medium leading-snug group-hover:opacity-80 transition-opacity">
        {entry.data.title}
      </h3>
      <p class="text-sm text-muted-foreground leading-relaxed">
        {entry.data.description}
      </p>
      <div class="flex items-center gap-2 text-sm text-muted-foreground">
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
        <span aria-hidden="true">·</span>
        <span>{authors}</span>
      </div>
    </div>
  </a>
</li>
